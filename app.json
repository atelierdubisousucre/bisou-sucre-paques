{
  "expo": {
    "name": "Joyeuses Paques Bisou Sucre",
    "slug": "bisou-sucre-paques",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo_rond.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo_rond.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF0F5"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bisousucre.paques",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera pour photos de Paques.",
        "NSPhotoLibraryAddUsageDescription": "Sauvegarder vos photos.",
        "NSPhotoLibraryUsageDescription": "Acces galerie."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_rond.png",
        "backgroundColor": "#FFF0F5"
      },
      "package": "com.bisousucre.paques",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/logo_rond.png",
      "bundler": "metro"
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Camera pour photos de Paques" }],
      ["expo-media-library", {
        "photosPermission": "Acces photos.",
        "savePhotosPermission": "Sauvegarder photos.",
        "isAccessMediaLocationEnabled": true
      }]
    ]
  }
}
